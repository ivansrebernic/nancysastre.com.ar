---
import { Picture } from 'astro:assets';
import heroImage from '../images/gallery/gallery-01.jpeg';

export interface Props {
  backgroundImage?: ImageMetadata;
  subtitle?: string;
  title?: string;
  titleHighlight?: string;
}

const {
  backgroundImage = heroImage,
  subtitle = 'Microfranquicia digital · 37 países',
  title = 'Construye un negocio inteligente',
  titleHighlight = 'en la industria del bienestar'
} = Astro.props;
---

<section id="hero-section" class="relative min-h-screen flex flex-col">
  <!-- Full-bleed photo: Nancy on the right stays fully visible -->
  <div class="absolute inset-0">
    <Picture
      src={backgroundImage}
      alt=""
      widths={[640, 768, 1024, 1280, 1920]}
      sizes="100vw"
      formats={['webp', 'jpeg']}
      loading="eager"
      class="w-full h-full object-cover object-[75%_center] md:object-center"
    />
    <!-- Desktop: left scrim behind the headline; the right side stays clean -->
    <div class="absolute inset-0 hidden md:block bg-gradient-to-r from-sage via-sage/75 via-35% to-transparent to-70%"></div>
    <!-- Mobile: right-anchored crop keeps Nancy in frame; soft bottom scrim -->
    <div class="absolute inset-0 md:hidden bg-gradient-to-t from-sage/95 via-sage/40 to-transparent"></div>
  </div>

  <!-- Headline pinned bottom-left -->
  <div class="relative z-10 flex-1 flex items-end px-6 md:px-12 pb-16 md:pb-20">
    <div class="max-w-4xl">
      <p class="inline-flex items-center gap-2.5 bg-primary-dark/90 text-sage text-xs md:text-sm uppercase tracking-[0.2em] rounded-full px-5 py-2.5 mb-6 animate-slide-down">
        <span class="w-2 h-2 rounded-full bg-lime-accent animate-pulse"></span>
        {subtitle}
      </p>
      <h1 class="font-fraunces font-medium text-4xl md:text-6xl lg:text-7xl leading-[1.05] text-primary-dark animate-slide-up">
        Construye<br />
        un negocio inteligente<br />
        <em class="text-primary">en la industria<br />
        del bienestar</em>
      </h1>
      <p class="mt-6 max-w-xl text-primary-dark/70 leading-relaxed animate-fade-in">
        Un sistema automatizado de bienestar que trabaja para vos
      </p>
      <div class="mt-8 animate-fade-in">
        <a href="#contact-wrap" class="btn-primary scroll-link px-8 py-3">
          Agendá tu entrevista
        </a>
      </div>
    </div>
  </div>
</section>
