---
// PROTOTYPE — Variant C3 "Bosque Bold": the Cinematic layout in the sage/forest
// green palette with Anton condensed display + hard 2px borders. Throwaway.
import { Image, Picture } from "astro:assets";
import { videos } from "../../data/videos";
import VideoEmbed from "../VideoEmbed.astro";
import heroImage from "../../images/gallery/gallery-01.jpeg";
import nancyPortrait from "../../images/gallery/gallery-02.jpeg";

const modules = import.meta.glob<{ default: ImageMetadata }>(
  "../../images/gallery/gallery-*.jpeg",
  { eager: true },
);
const galleryImages = Object.entries(modules)
  .sort(([a], [b]) => a.localeCompare(b))
  .map(([, m]) => m.default)
  .slice(22, 30)
  .concat(
    Object.entries(modules)
      .sort(([a], [b]) => a.localeCompare(b))
      .map(([, m]) => m.default)
      .slice(2, 6),
  );

const stats = [
  { number: "37", label: "Países en operación" },
  { number: "7d", label: "Comisiones semanales" },
  { number: "0", label: "Stock e inventario" },
];
---

<link
  rel="stylesheet"
  href="https://fonts.googleapis.com/css2?family=Anton&family=Schibsted+Grotesk:ital,wght@0,400;0,500;0,700;1,400&display=swap"
/>

<div class="proto-c3 bg-[#eef1e9] text-[#182c21]">
  <!-- Hero: full screen, white-out cinematic -->
  <section class="relative min-h-screen flex flex-col">
    <div class="absolute inset-0">
      <Picture
        src={heroImage}
        alt=""
        widths={[768, 1280, 1920]}
        sizes="100vw"
        formats={["webp"]}
        loading="eager"
        class="w-full h-full object-cover object-[75%_center] md:object-center"
      />
      <div class="absolute inset-0 hidden md:block bg-gradient-to-r from-[#eef1e9] via-[#eef1e9]/70 via-30% to-transparent to-60%"></div>
      <div class="absolute inset-0 md:hidden bg-gradient-to-t from-[#eef1e9]/95 via-[#eef1e9]/40 to-transparent"></div>
    </div>

    <header class="relative z-10 flex items-center justify-between px-6 md:px-12 py-6">
      <p class="font-cond text-2xl uppercase text-[#182c21]">Nancy Sastre</p>
      <a
        href="#cierre-c3"
        class="font-body-c3 text-xs uppercase tracking-[0.25em] bg-[#2e5e41] text-white px-6 py-3 hover:bg-[#182c21] transition-colors"
      >
        Entrevista
      </a>
    </header>

    <div class="relative z-10 flex-1 flex items-end px-6 md:px-12 pb-20">
      <div class="max-w-4xl">
        <p class="font-body-c3 text-[#2e5e41] text-xs uppercase tracking-[0.35em] font-bold mb-5">
          Microfranquicia digital · 37 países
        </p>
        <h1 class="font-cond text-7xl md:text-8xl lg:text-9xl leading-[0.92] uppercase text-[#182c21]">
          Tu tiempo no<br />
          se <span class="text-[#2e5e41]">negocia.</span>
        </h1>
        <p class="font-body-c3 mt-6 max-w-xl text-[#44584b] leading-relaxed">
          Un sistema automatizado de bienestar, respaldado por ciencia, que trabaja para vos —
          y no al revés.
        </p>
      </div>
    </div>

  </section>

  <!-- Stats band -->
  <div class="border-y-2 border-[#182c21] bg-[#eef1e9]">
    <div class="grid grid-cols-3 divide-x-2 divide-[#182c21]">
      {stats.map((s) => (
        <div class="px-6 md:px-12 py-6">
          <p class="font-cond text-4xl md:text-5xl text-[#2e5e41]">{s.number}</p>
          <p class="font-body-c3 text-xs uppercase tracking-widest text-[#44584b] mt-1">{s.label}</p>
        </div>
      ))}
    </div>
  </div>

  <!-- Paso 2 — Videos -->
  <section class="px-6 md:px-12 py-24">
    <div class="max-w-5xl mx-auto">
      <p class="font-body-c3 text-[#2e5e41] text-xs uppercase tracking-[0.35em] font-bold mb-3">
        El vehículo comercial
      </p>
      <h2 class="font-cond text-5xl md:text-7xl uppercase text-[#182c21] mb-14">
        La envergadura del proyecto
      </h2>
      <div class="space-y-16">
        <div class="grid grid-cols-1 md:grid-cols-12 gap-6 items-end">
          <div class="md:col-span-9">
            <VideoEmbed video={videos.product} />
          </div>
          <div class="md:col-span-3">
            <p class="font-cond text-4xl text-[#b9c6ae]">01</p>
            <p class="font-body-c3 text-sm text-[#44584b]">{videos.product.placeholderLabel}</p>
          </div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-12 gap-6 items-end">
          <div class="md:col-span-3 order-2 md:order-1 text-right md:text-left">
            <p class="font-cond text-4xl text-[#b9c6ae]">02</p>
            <p class="font-body-c3 text-sm text-[#44584b]">{videos.corporate.placeholderLabel}</p>
          </div>
          <div class="md:col-span-9 order-1 md:order-2">
            <VideoEmbed video={videos.corporate} />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Paso 3 — Historia -->
  <section class="border-y-2 border-[#182c21] bg-[#e2e8da]">
    <div class="max-w-5xl mx-auto px-6 md:px-12 py-24 grid grid-cols-1 md:grid-cols-12 gap-12 items-center">
      <div class="md:col-span-4">
        <div class="relative">
          <Image
            src={nancyPortrait}
            alt="Nancy Sastre"
            widths={[400, 600]}
            sizes="(max-width: 768px) 90vw, 340px"
            loading="lazy"
            class="w-full h-[420px] object-cover object-top"
          />
          <div class="absolute -bottom-3 -right-3 bg-[#2e5e41] text-white px-4 py-2 font-cond text-xl uppercase">
            Tu mentora
          </div>
        </div>
      </div>
      <div class="md:col-span-8">
        <p class="font-body-c3 text-[#2e5e41] text-xs uppercase tracking-[0.35em] font-bold mb-3">Quién te guía</p>
        <h2 class="font-cond text-5xl uppercase text-[#182c21] mb-8">Nancy Sastre</h2>
        <div class="font-body-c3 space-y-5 text-[#44584b] leading-relaxed border-l-2 border-[#2e5e41] pl-6">
          <p>
            Mi nombre es Nancy Sastre. Durante años me dediqué al comercio tradicional y a la
            gestión de mi propio espacio (mi querida casa de té). Descubrí que el negocio
            tradicional tiene un límite físico: si querés que crezca, tenés que entregar lo más
            valioso que tenés, que es tu tiempo libre.
          </p>
          <p>
            Encontré en las microfranquicias digitales y el dropshipping internacional la
            respuesta exacta: un sistema automatizado que opera en 37 países, respaldado por la
            ciencia de vanguardia de FuXion, manejado desde mis propios tiempos y espacios.
          </p>
          <p>
            Hoy mi misión no es vender un producto, sino acompañarte a integrar esta
            infraestructura llave en mano dentro de tu profesión, tu agenda y tus objetivos.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Paso 4a — Galería -->
  <section class="py-24 overflow-hidden">
    <div class="px-6 md:px-12 mb-10 flex items-end justify-between max-w-full">
      <div>
        <p class="font-body-c3 text-[#2e5e41] text-xs uppercase tracking-[0.35em] font-bold mb-3">
          El estilo de vida
        </p>
        <h2 class="font-cond text-5xl uppercase text-[#182c21]">Viajes, bonos, comunidad</h2>
      </div>
      <p class="font-body-c3 hidden md:block text-xs text-[#8da183] uppercase tracking-widest">Deslizá →</p>
    </div>
    <div class="flex gap-4 overflow-x-auto snap-x snap-mandatory px-6 md:px-12 pb-4">
      {galleryImages.map((img, i) => (
        <div class="snap-start shrink-0 w-64 md:w-80">
          <Image
            src={img}
            alt={`Nancy Sastre — estilo de vida ${i + 1}`}
            widths={[300, 500]}
            sizes="320px"
            loading="lazy"
            class="w-full h-80 md:h-96 object-cover"
          />
        </div>
      ))}
    </div>
  </section>

  <!-- Paso 4b — Cierre -->
  <section id="cierre-c3" class="border-t-2 border-[#182c21] px-6 md:px-12 py-24 bg-[#e2e8da]">
    <div class="max-w-3xl mx-auto text-center">
      <p class="font-body-c3 text-[#2e5e41] text-xs uppercase tracking-[0.35em] font-bold mb-3">El cierre</p>
      <h2 class="font-cond text-5xl md:text-7xl uppercase text-[#182c21] mb-10">
        Un mensaje para vos
      </h2>
      <VideoEmbed video={videos.personal} />

      <form class="mt-16 text-left space-y-4" onsubmit="return false">
        <p class="font-body-c3 text-[10px] uppercase tracking-[0.25em] text-[#8da183] text-center">
          Formulario ilustrativo — prototipo
        </p>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {
            ["Nombre", "Email", "WhatsApp", "País de residencia"].map((label) => (
              <input
                type="text"
                placeholder={label}
                class="font-body-c3 bg-white border-2 border-[#182c21]/20 focus:border-[#2e5e41] outline-none px-4 py-3.5 text-[#182c21] placeholder:text-[#8da183]"
              />
            ))
          }
        </div>
        <select class="font-body-c3 w-full bg-white border-2 border-[#182c21]/20 focus:border-[#2e5e41] outline-none px-4 py-3.5 text-[#44584b]">
          <option>Perfil actual</option>
          <option>Profesional de la salud / Bienestar</option>
          <option>Emprendedor / Comerciante</option>
          <option>Creador de contenido / Influencer</option>
          <option>Primer emprendimiento digital</option>
        </select>
        <select class="font-body-c3 w-full bg-white border-2 border-[#182c21]/20 focus:border-[#2e5e41] outline-none px-4 py-3.5 text-[#44584b]">
          <option>Tiempo semanal disponible</option>
          <option>De 2 a 5 horas semanales</option>
          <option>De 5 a 12 horas semanales</option>
          <option>Más de 12 horas</option>
        </select>
        <button
          type="button"
          class="font-cond w-full bg-[#2e5e41] text-white text-2xl uppercase tracking-wide py-4 hover:bg-[#182c21] transition-colors"
        >
          Solicitar mi entrevista
        </button>
      </form>
    </div>
  </section>

  <footer class="border-t-2 border-[#182c21] px-6 md:px-12 py-6 flex items-center justify-between text-xs text-[#8da183] font-body-c3">
    <span class="font-cond text-lg uppercase text-[#182c21]">Nancy Sastre</span>
    <span>Empresaria independiente FuXion</span>
  </footer>
</div>

<style>
  .proto-c3 .font-cond,
  .proto-c3 h1,
  .proto-c3 h2 {
    font-family: "Anton", "Arial Narrow", sans-serif;
    font-weight: 400;
  }
  .proto-c3 .font-body-c3,
  .proto-c3 p,
  .proto-c3 input,
  .proto-c3 select,
  .proto-c3 a {
    font-family: "Schibsted Grotesk", sans-serif;
  }
</style>
