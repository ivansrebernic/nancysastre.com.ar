---
// PROTOTYPE — Variant C "Cinemático": full-bleed dark, amber accent, video-first,
// horizontal gallery strip. Follows Nancy's funnel. Throwaway code — do not ship.
import { Image, Picture } from "astro:assets";
import { videos } from "../../data/videos";
import VideoEmbed from "../VideoEmbed.astro";
import heroImage from "../../images/gallery/gallery-01.jpeg";
import nancyPortrait from "../../images/gallery/gallery-02.jpeg";
import logoImage from "../../images/LOGO.png";

const modules = import.meta.glob<{ default: ImageMetadata }>(
  "../../images/gallery/gallery-*.jpeg",
  { eager: true },
);
const galleryImages = Object.entries(modules)
  .sort(([a], [b]) => a.localeCompare(b))
  .map(([, m]) => m.default)
  .slice(12, 24);

const stats = [
  { number: "37", label: "Países en operación" },
  { number: "7d", label: "Comisiones semanales" },
  { number: "0", label: "Stock e inventario" },
];
---

<div class="bg-zinc-950 text-zinc-100 font-poppins">
  <!-- Hero: full screen, cinematic -->
  <section class="relative min-h-screen flex flex-col">
    <div class="absolute inset-0">
      <Picture
        src={heroImage}
        alt=""
        widths={[768, 1280, 1920]}
        sizes="100vw"
        formats={["webp"]}
        loading="eager"
        class="w-full h-full object-cover object-[75%_center] md:object-center"
      />
      <div class="absolute inset-0 hidden md:block bg-gradient-to-r from-zinc-950/95 via-zinc-950/45 via-25% to-transparent to-55%"></div>
      <div class="absolute inset-0 md:hidden bg-gradient-to-t from-zinc-950/95 via-zinc-950/40 to-transparent"></div>
    </div>

    <header class="relative z-10 flex items-center justify-between px-6 md:px-12 py-6">
      <Image
        src={logoImage}
        alt="Empresario Independiente Fuxion"
        width={200}
        height={72}
        loading="eager"
        class="h-10 w-auto brightness-0 invert opacity-90"
      />
      <a
        href="#cierre-c"
        class="text-xs uppercase tracking-[0.25em] text-amber-400 border border-amber-400/60 px-5 py-2.5 hover:bg-amber-400 hover:text-zinc-950 transition-colors"
      >
        Entrevista
      </a>
    </header>

    <div class="relative z-10 flex-1 flex items-end px-6 md:px-12 pb-24">
      <div class="max-w-4xl">
        <p class="text-amber-400 text-xs uppercase tracking-[0.35em] mb-5">
          Microfranquicia digital · 37 países
        </p>
        <h1 class="text-white font-bebas text-6xl md:text-8xl lg:text-9xl leading-[0.95] uppercase">
          Tu tiempo no se<br />
          <span class="text-amber-400">negocia.</span>
        </h1>
        <p class="mt-6 max-w-xl text-zinc-300 leading-relaxed">
          Un sistema automatizado de bienestar, respaldado por ciencia, que trabaja para vos —
          y no al revés.
        </p>
      </div>
    </div>

  </section>

  <!-- Stats band -->
  <div class="border-y border-zinc-800 bg-zinc-950">
    <div class="grid grid-cols-3 divide-x divide-zinc-800">
      {stats.map((s) => (
        <div class="px-6 md:px-12 py-6">
          <p class="font-bebas text-4xl md:text-5xl text-amber-400">{s.number}</p>
          <p class="text-xs uppercase tracking-widest text-zinc-400 mt-1">{s.label}</p>
        </div>
      ))}
    </div>
  </div>

  <!-- Paso 2 — Videos corporativos, full width stacked -->
  <section class="px-6 md:px-12 py-24">
    <div class="max-w-5xl mx-auto">
      <p class="text-amber-400 text-xs uppercase tracking-[0.35em] mb-3">El vehículo comercial</p>
      <h2 class="text-white font-bebas text-5xl md:text-6xl uppercase mb-14">
        La envergadura del proyecto
      </h2>
      <div class="space-y-16">
        <div class="grid grid-cols-1 md:grid-cols-12 gap-6 items-end">
          <div class="md:col-span-9">
            <VideoEmbed video={videos.product} />
          </div>
          <div class="md:col-span-3">
            <p class="font-bebas text-3xl text-zinc-600">01</p>
            <p class="text-sm text-zinc-400">{videos.product.placeholderLabel}</p>
          </div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-12 gap-6 items-end">
          <div class="md:col-span-3 order-2 md:order-1 text-right md:text-left">
            <p class="font-bebas text-3xl text-zinc-600">02</p>
            <p class="text-sm text-zinc-400">{videos.corporate.placeholderLabel}</p>
          </div>
          <div class="md:col-span-9 order-1 md:order-2">
            <VideoEmbed video={videos.corporate} />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Paso 3 — Historia compacta -->
  <section class="border-y border-zinc-800 bg-zinc-900/50">
    <div class="max-w-5xl mx-auto px-6 md:px-12 py-24 grid grid-cols-1 md:grid-cols-12 gap-12 items-center">
      <div class="md:col-span-4">
        <div class="relative">
          <Image
            src={nancyPortrait}
            alt="Nancy Sastre"
            widths={[400, 600]}
            sizes="(max-width: 768px) 90vw, 340px"
            loading="lazy"
            class="w-full h-[420px] object-cover object-top"
          />
          <div class="absolute -bottom-3 -right-3 bg-amber-400 text-zinc-950 px-4 py-2 font-bebas text-xl uppercase">
            Tu mentora
          </div>
        </div>
      </div>
      <div class="md:col-span-8">
        <p class="text-amber-400 text-xs uppercase tracking-[0.35em] mb-3">Quién te guía</p>
        <h2 class="text-white font-bebas text-5xl uppercase mb-8">Nancy Sastre</h2>
        <div class="space-y-5 text-zinc-300 leading-relaxed border-l-2 border-amber-400/60 pl-6">
          <p>
            Mi nombre es Nancy Sastre. Durante años me dediqué al comercio tradicional y a la
            gestión de mi propio espacio (mi querida casa de té). Descubrí que el negocio
            tradicional tiene un límite físico: si querés que crezca, tenés que entregar lo más
            valioso que tenés, que es tu tiempo libre.
          </p>
          <p>
            Encontré en las microfranquicias digitales y el dropshipping internacional la
            respuesta exacta: un sistema automatizado que opera en 37 países, respaldado por la
            ciencia de vanguardia de FuXion, manejado desde mis propios tiempos y espacios.
          </p>
          <p>
            Hoy mi misión no es vender un producto, sino acompañarte a integrar esta
            infraestructura llave en mano dentro de tu profesión, tu agenda y tus objetivos.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Paso 4a — Galería: cinta horizontal -->
  <section class="py-24 overflow-hidden">
    <div class="px-6 md:px-12 mb-10 flex items-end justify-between max-w-full">
      <div>
        <p class="text-amber-400 text-xs uppercase tracking-[0.35em] mb-3">El estilo de vida</p>
        <h2 class="text-white font-bebas text-5xl uppercase">Viajes, bonos, comunidad</h2>
      </div>
      <p class="hidden md:block text-xs text-zinc-500 uppercase tracking-widest">
        Deslizá →
      </p>
    </div>
    <div class="flex gap-4 overflow-x-auto snap-x snap-mandatory px-6 md:px-12 pb-4">
      {galleryImages.map((img, i) => (
        <div class="snap-start shrink-0 w-64 md:w-80">
          <Image
            src={img}
            alt={`Nancy Sastre — estilo de vida ${i + 1}`}
            widths={[300, 500]}
            sizes="320px"
            loading="lazy"
            class="w-full h-80 md:h-96 object-cover"
          />
        </div>
      ))}
    </div>
  </section>

  <!-- Paso 4b — Video 1 min + formulario -->
  <section id="cierre-c" class="border-t border-zinc-800 px-6 md:px-12 py-24">
    <div class="max-w-3xl mx-auto text-center">
      <p class="text-amber-400 text-xs uppercase tracking-[0.35em] mb-3">El cierre</p>
      <h2 class="text-white font-bebas text-5xl md:text-6xl uppercase mb-10">
        Un mensaje para vos
      </h2>
      <VideoEmbed video={videos.personal} />

      <form class="mt-16 text-left space-y-4" onsubmit="return false">
        <p class="text-[10px] uppercase tracking-[0.25em] text-zinc-600 text-center">
          Formulario ilustrativo — prototipo
        </p>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {
            [
              { label: "Nombre", type: "text" },
              { label: "Email", type: "email" },
              { label: "WhatsApp", type: "tel" },
              { label: "País de residencia", type: "text" },
            ].map((f) => (
              <input
                type={f.type}
                placeholder={f.label}
                class="bg-zinc-900 border border-zinc-700 focus:border-amber-400 outline-none px-4 py-3.5 text-zinc-100 placeholder:text-zinc-500"
              />
            ))
          }
        </div>
        <select class="w-full bg-zinc-900 border border-zinc-700 focus:border-amber-400 outline-none px-4 py-3.5 text-zinc-400">
          <option>Perfil actual</option>
          <option>Profesional de la salud / Bienestar</option>
          <option>Emprendedor / Comerciante</option>
          <option>Creador de contenido / Influencer</option>
          <option>Primer emprendimiento digital</option>
        </select>
        <select class="w-full bg-zinc-900 border border-zinc-700 focus:border-amber-400 outline-none px-4 py-3.5 text-zinc-400">
          <option>Tiempo semanal disponible</option>
          <option>De 2 a 5 horas semanales</option>
          <option>De 5 a 12 horas semanales</option>
          <option>Más de 12 horas</option>
        </select>
        <button
          type="button"
          class="w-full bg-amber-400 text-zinc-950 font-bebas text-2xl uppercase tracking-wide py-4 hover:bg-amber-300 transition-colors"
        >
          Solicitar mi entrevista
        </button>
      </form>
    </div>
  </section>

  <footer class="border-t border-zinc-800 px-6 md:px-12 py-6 flex items-center justify-between text-xs text-zinc-500">
    <span class="font-bebas text-lg text-zinc-400 uppercase">Nancy Sastre</span>
    <span>Empresaria independiente FuXion</span>
  </footer>
</div>
