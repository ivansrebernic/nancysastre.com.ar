---
// PROTOTYPE — Variant C2 "Cine Alba": the Cinematic layout in a warm light
// palette — ivory, espresso, copper; Fraunces display. Throwaway — do not ship.
import { Image, Picture } from "astro:assets";
import { videos } from "../../data/videos";
import VideoEmbed from "../VideoEmbed.astro";
import heroImage from "../../images/gallery/gallery-01.jpeg";
import nancyPortrait from "../../images/gallery/gallery-02.jpeg";

const modules = import.meta.glob<{ default: ImageMetadata }>(
  "../../images/gallery/gallery-*.jpeg",
  { eager: true },
);
const galleryImages = Object.entries(modules)
  .sort(([a], [b]) => a.localeCompare(b))
  .map(([, m]) => m.default)
  .slice(12, 24);

const stats = [
  { number: "37", label: "Países en operación" },
  { number: "7d", label: "Comisiones semanales" },
  { number: "0", label: "Stock e inventario" },
];
---

<link
  rel="stylesheet"
  href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,600;1,9..144,400&family=Albert+Sans:wght@300;400;500;600&display=swap"
/>

<div class="proto-c2 bg-[#f7f3ec] text-[#221c14]">
  <!-- Hero: full screen, light cinematic -->
  <section class="relative min-h-screen flex flex-col">
    <div class="absolute inset-0">
      <Picture
        src={heroImage}
        alt=""
        widths={[768, 1280, 1920]}
        sizes="100vw"
        formats={["webp"]}
        loading="eager"
        class="w-full h-full object-cover object-[75%_center] md:object-center"
      />
      <div class="absolute inset-0 hidden md:block bg-gradient-to-r from-[#f7f3ec] via-[#f7f3ec]/70 via-30% to-transparent to-60%"></div>
      <div class="absolute inset-0 md:hidden bg-gradient-to-t from-[#f7f3ec]/95 via-[#f7f3ec]/40 to-transparent"></div>
    </div>

    <header class="relative z-10 flex items-center justify-between px-6 md:px-12 py-6">
      <p class="font-disp text-2xl text-[#221c14]">Nancy Sastre</p>
      <a
        href="#cierre-c2"
        class="font-body-c2 text-xs uppercase tracking-[0.25em] bg-[#221c14] text-[#f7f3ec] px-6 py-3 rounded-full hover:bg-[#c05621] transition-colors"
      >
        Entrevista
      </a>
    </header>

    <div class="relative z-10 flex-1 flex items-end px-6 md:px-12 pb-20">
      <div class="max-w-4xl">
        <p class="font-body-c2 text-[#c05621] text-xs uppercase tracking-[0.35em] mb-5">
          Microfranquicia digital · 37 países
        </p>
        <h1 class="font-disp text-6xl md:text-8xl lg:text-[7rem] leading-[0.98] text-[#221c14]">
          Tu tiempo no<br />
          se <em class="text-[#c05621]">negocia.</em>
        </h1>
        <p class="font-body-c2 mt-6 max-w-xl text-[#5c5244] leading-relaxed">
          Un sistema automatizado de bienestar, respaldado por ciencia, que trabaja para vos —
          y no al revés.
        </p>
      </div>
    </div>

  </section>

  <!-- Stats band -->
  <div class="border-y border-[#221c14]/15 bg-[#f7f3ec]">
    <div class="grid grid-cols-3 divide-x divide-[#221c14]/15">
      {stats.map((s) => (
        <div class="px-6 md:px-12 py-6">
          <p class="font-disp text-4xl md:text-5xl text-[#c05621]">{s.number}</p>
          <p class="font-body-c2 text-xs uppercase tracking-widest text-[#5c5244] mt-1">{s.label}</p>
        </div>
      ))}
    </div>
  </div>

  <!-- Paso 2 — Videos -->
  <section class="px-6 md:px-12 py-24">
    <div class="max-w-5xl mx-auto">
      <p class="font-body-c2 text-[#c05621] text-xs uppercase tracking-[0.35em] mb-3">El vehículo comercial</p>
      <h2 class="font-disp text-4xl md:text-6xl text-[#221c14] mb-14">La envergadura del proyecto</h2>
      <div class="space-y-16">
        <div class="grid grid-cols-1 md:grid-cols-12 gap-6 items-end">
          <div class="md:col-span-9">
            <VideoEmbed video={videos.product} />
          </div>
          <div class="md:col-span-3">
            <p class="font-disp text-3xl text-[#c9bda9]">01</p>
            <p class="font-body-c2 text-sm text-[#5c5244]">{videos.product.placeholderLabel}</p>
          </div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-12 gap-6 items-end">
          <div class="md:col-span-3 order-2 md:order-1 text-right md:text-left">
            <p class="font-disp text-3xl text-[#c9bda9]">02</p>
            <p class="font-body-c2 text-sm text-[#5c5244]">{videos.corporate.placeholderLabel}</p>
          </div>
          <div class="md:col-span-9 order-1 md:order-2">
            <VideoEmbed video={videos.corporate} />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Paso 3 — Historia -->
  <section class="border-y border-[#221c14]/10 bg-[#efe8db]">
    <div class="max-w-5xl mx-auto px-6 md:px-12 py-24 grid grid-cols-1 md:grid-cols-12 gap-12 items-center">
      <div class="md:col-span-4">
        <div class="relative">
          <Image
            src={nancyPortrait}
            alt="Nancy Sastre"
            widths={[400, 600]}
            sizes="(max-width: 768px) 90vw, 340px"
            loading="lazy"
            class="w-full h-[420px] object-cover object-top rounded-t-full"
          />
          <div class="absolute -bottom-3 -right-3 bg-[#c05621] text-[#f7f3ec] px-5 py-2 font-disp text-lg rounded-full">
            Tu mentora
          </div>
        </div>
      </div>
      <div class="md:col-span-8">
        <p class="font-body-c2 text-[#c05621] text-xs uppercase tracking-[0.35em] mb-3">Quién te guía</p>
        <h2 class="font-disp text-4xl md:text-5xl text-[#221c14] mb-8">Nancy Sastre</h2>
        <div class="font-body-c2 space-y-5 text-[#4a4337] leading-relaxed border-l-2 border-[#c05621]/60 pl-6">
          <p>
            Mi nombre es Nancy Sastre. Durante años me dediqué al comercio tradicional y a la
            gestión de mi propio espacio (mi querida casa de té). Descubrí que el negocio
            tradicional tiene un límite físico: si querés que crezca, tenés que entregar lo más
            valioso que tenés, que es tu tiempo libre.
          </p>
          <p>
            Encontré en las microfranquicias digitales y el dropshipping internacional la
            respuesta exacta: un sistema automatizado que opera en 37 países, respaldado por la
            ciencia de vanguardia de FuXion, manejado desde mis propios tiempos y espacios.
          </p>
          <p>
            Hoy mi misión no es vender un producto, sino acompañarte a integrar esta
            infraestructura llave en mano dentro de tu profesión, tu agenda y tus objetivos.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Paso 4a — Galería: cinta horizontal -->
  <section class="py-24 overflow-hidden">
    <div class="px-6 md:px-12 mb-10 flex items-end justify-between max-w-full">
      <div>
        <p class="font-body-c2 text-[#c05621] text-xs uppercase tracking-[0.35em] mb-3">El estilo de vida</p>
        <h2 class="font-disp text-4xl md:text-5xl text-[#221c14]">Viajes, bonos, comunidad</h2>
      </div>
      <p class="font-body-c2 hidden md:block text-xs text-[#a39782] uppercase tracking-widest">Deslizá →</p>
    </div>
    <div class="flex gap-4 overflow-x-auto snap-x snap-mandatory px-6 md:px-12 pb-4">
      {galleryImages.map((img, i) => (
        <div class="snap-start shrink-0 w-64 md:w-80">
          <Image
            src={img}
            alt={`Nancy Sastre — estilo de vida ${i + 1}`}
            widths={[300, 500]}
            sizes="320px"
            loading="lazy"
            class="w-full h-80 md:h-96 object-cover rounded-2xl"
          />
        </div>
      ))}
    </div>
  </section>

  <!-- Paso 4b — Cierre -->
  <section id="cierre-c2" class="border-t border-[#221c14]/10 px-6 md:px-12 py-24 bg-[#efe8db]">
    <div class="max-w-3xl mx-auto text-center">
      <p class="font-body-c2 text-[#c05621] text-xs uppercase tracking-[0.35em] mb-3">El cierre</p>
      <h2 class="font-disp text-4xl md:text-6xl text-[#221c14] mb-10">Un mensaje para vos</h2>
      <VideoEmbed video={videos.personal} />

      <form class="mt-16 text-left space-y-4" onsubmit="return false">
        <p class="font-body-c2 text-[10px] uppercase tracking-[0.25em] text-[#a39782] text-center">
          Formulario ilustrativo — prototipo
        </p>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {
            ["Nombre", "Email", "WhatsApp", "País de residencia"].map((label) => (
              <input
                type="text"
                placeholder={label}
                class="font-body-c2 bg-white border border-[#221c14]/15 focus:border-[#c05621] outline-none px-4 py-3.5 rounded-xl text-[#221c14] placeholder:text-[#a39782]"
              />
            ))
          }
        </div>
        <select class="font-body-c2 w-full bg-white border border-[#221c14]/15 focus:border-[#c05621] outline-none px-4 py-3.5 rounded-xl text-[#5c5244]">
          <option>Perfil actual</option>
          <option>Profesional de la salud / Bienestar</option>
          <option>Emprendedor / Comerciante</option>
          <option>Creador de contenido / Influencer</option>
          <option>Primer emprendimiento digital</option>
        </select>
        <select class="font-body-c2 w-full bg-white border border-[#221c14]/15 focus:border-[#c05621] outline-none px-4 py-3.5 rounded-xl text-[#5c5244]">
          <option>Tiempo semanal disponible</option>
          <option>De 2 a 5 horas semanales</option>
          <option>De 5 a 12 horas semanales</option>
          <option>Más de 12 horas</option>
        </select>
        <button
          type="button"
          class="font-disp w-full bg-[#c05621] text-[#f7f3ec] text-2xl py-4 rounded-xl hover:bg-[#a8491b] transition-colors"
        >
          Solicitar mi entrevista
        </button>
      </form>
    </div>
  </section>

  <footer class="border-t border-[#221c14]/10 px-6 md:px-12 py-6 flex items-center justify-between text-xs text-[#a39782] font-body-c2">
    <span class="font-disp text-lg text-[#221c14]">Nancy Sastre</span>
    <span>Empresaria independiente FuXion</span>
  </footer>
</div>

<style>
  .proto-c2 .font-disp,
  .proto-c2 h1,
  .proto-c2 h2 {
    font-family: "Fraunces", Georgia, serif;
    font-weight: 600;
  }
  .proto-c2 .font-body-c2,
  .proto-c2 p,
  .proto-c2 input,
  .proto-c2 select,
  .proto-c2 a {
    font-family: "Albert Sans", sans-serif;
  }
</style>
