---
---

<section id="contact-wrap" class="py-12 md:py-16">
  <div class="container-narrow">
    <!-- Section Header -->
    <div class="text-center max-w-2xl mx-auto mb-8">
      <p class="section-title">ÚLTIMO PASO</p>
      <h3 class="section-heading mb-4 text-gray-900">Coordiná tu entrevista personalizada</h3>
      <p class="text-gray-600">
        Si querés evaluar la viabilidad de sumarte a Fuxion, completá el formulario a continuación.
        Tus respuestas me permiten preparar una entrevista a la medida de tu perfil y tus objetivos.
      </p>
    </div>

    <!-- Qualifying Form -->
    <div class="max-w-2xl mx-auto">
      <form
        id="contact-form"
        class="space-y-6"
        method="POST"
        action="https://formsubmit.co/nancyloschalets@gmail.com"
      >
        <!-- FormSubmit Configuration -->
        <input type="hidden" name="_subject" value="Nueva solicitud de entrevista - Microfranquicia Digital" />
        <input type="hidden" name="_captcha" value="false" />
        <input type="text" name="_honey" style="display:none" />
        <input type="hidden" name="type" value="entrevista" />

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <!-- Name -->
          <div>
            <label for="name" class="block text-sm uppercase tracking-wider mb-2 text-gray-600">Nombre</label>
            <input
              type="text"
              id="name"
              name="Nombre"
              placeholder="Tu nombre"
              required
              class="w-full px-4 py-3 bg-white border-2 border-gray-200 rounded text-gray-900 placeholder-gray-500 focus:border-primary focus:outline-none transition-all duration-300 hover:border-gray-300"
            />
          </div>

          <!-- Email -->
          <div>
            <label for="email" class="block text-sm uppercase tracking-wider mb-2 text-gray-600">Email</label>
            <input
              type="email"
              id="email"
              name="Email"
              placeholder="tucorreo@ejemplo.com"
              required
              class="w-full px-4 py-3 bg-white border-2 border-gray-200 rounded text-gray-900 placeholder-gray-500 focus:border-primary focus:outline-none transition-all duration-300 hover:border-gray-300"
            />
          </div>

          <!-- WhatsApp -->
          <div>
            <label for="whatsapp" class="block text-sm uppercase tracking-wider mb-2 text-gray-600">WhatsApp</label>
            <input
              type="tel"
              id="whatsapp"
              name="WhatsApp"
              placeholder="+54 9 ..."
              required
              class="w-full px-4 py-3 bg-white border-2 border-gray-200 rounded text-gray-900 placeholder-gray-500 focus:border-primary focus:outline-none transition-all duration-300 hover:border-gray-300"
            />
          </div>

          <!-- Country -->
          <div>
            <label for="pais" class="block text-sm uppercase tracking-wider mb-2 text-gray-600">País de residencia</label>
            <input
              type="text"
              id="pais"
              name="Pais de residencia"
              placeholder="Tu país"
              required
              class="w-full px-4 py-3 bg-white border-2 border-gray-200 rounded text-gray-900 placeholder-gray-500 focus:border-primary focus:outline-none transition-all duration-300 hover:border-gray-300"
            />
          </div>
        </div>

        <!-- Q1: Perfil -->
        <div>
          <label for="perfil" class="block text-sm uppercase tracking-wider mb-2 text-gray-600">¿Cuál es tu perfil actual?</label>
          <select
            id="perfil"
            name="Perfil actual"
            required
            class="w-full px-4 py-3 bg-white border-2 border-gray-200 rounded text-gray-900 focus:border-primary focus:outline-none transition-all duration-300 hover:border-gray-300"
          >
            <option value="" disabled selected>Seleccioná una opción</option>
            <option>Profesional de la salud / Bienestar</option>
            <option>Emprendedor / Comerciante / Dueño de negocio</option>
            <option>Creador de contenido / Influencer</option>
            <option>Busco mi primer emprendimiento digital / Manejo del hogar</option>
          </select>
        </div>

        <!-- Q2: Tiempo semanal -->
        <div>
          <label for="tiempo" class="block text-sm uppercase tracking-wider mb-2 text-gray-600">¿Cuánto tiempo semanal dispones para desarrollar tu microfranquicia?</label>
          <select
            id="tiempo"
            name="Tiempo semanal disponible"
            required
            class="w-full px-4 py-3 bg-white border-2 border-gray-200 rounded text-gray-900 focus:border-primary focus:outline-none transition-all duration-300 hover:border-gray-300"
          >
            <option value="" disabled selected>Seleccioná una opción</option>
            <option>De 2 a 5 horas semanales (Como ingreso extra)</option>
            <option>De 5 a 12 horas semanales (Enfoque de crecimiento rápido)</option>
            <option>Más de 12 horas (Dedicación exclusiva)</option>
          </select>
        </div>

        <!-- Q3: Objetivo -->
        <div>
          <label for="objetivo" class="block text-sm uppercase tracking-wider mb-2 text-gray-600">¿Cuál es tu principal objetivo al postularte a esta entrevista?</label>
          <select
            id="objetivo"
            name="Objetivo principal"
            required
            class="w-full px-4 py-3 bg-white border-2 border-gray-200 rounded text-gray-900 focus:border-primary focus:outline-none transition-all duration-300 hover:border-gray-300"
          >
            <option value="" disabled selected>Seleccioná una opción</option>
            <option>Conocer cómo generar ingresos residuales en dólares/euros desde mi país.</option>
            <option>Aprender a usar sistemas digitales y automatizados aplicados al bienestar.</option>
            <option>Diversificar mis ingresos actuales sin descuidar mi profesión.</option>
          </select>
        </div>

        <!-- Flash Messages -->
        <div id="flash-message" class="flashinfo hidden bg-white px-12 py-4 rounded relative border border-gray-200">
          <span class="material-icons absolute left-4 top-1/2 transform -translate-y-1/2 text-primary"></span>
          <span class="message-text"></span>
        </div>

        <!-- Submit -->
        <div class="text-center">
          <button
            type="submit"
            class="btn-primary px-12 py-4 font-scandia-medium tracking-wider hover:shadow-large transform hover:scale-105 transition-all duration-300"
            id="submit-btn"
          >
            <span class="relative z-10">QUIERO MI ENTREVISTA</span>
          </button>
        </div>
      </form>
    </div>
  </div>
</section>

<style>
  input:focus,
  select:focus {
    background-color: #ffffff;
    box-shadow: 0 4px 20px rgba(1, 134, 214, 0.15);
  }

  input,
  select {
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .flashinfo {
    transition: all 0.3s ease;
  }

  .flashinfo.show {
    display: block;
    animation: slideIn 0.3s ease-out;
  }

  @keyframes slideIn {
    from {
      opacity: 0;
      transform: translateY(-10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const flashMessage = document.getElementById('flash-message');
  const messageText = flashMessage?.querySelector('.message-text');
  const messageIcon = flashMessage?.querySelector('.material-icons');
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;

  function showMessage(message: string, type: 'success' | 'error' | 'loading') {
    if (!flashMessage || !messageText || !messageIcon) return;

    flashMessage.classList.remove('hidden', 'bg-white', 'bg-green-50', 'bg-red-50');
    flashMessage.classList.add('show');
    messageText.textContent = message;

    if (type === 'loading') {
      messageIcon.textContent = 'hourglass_bottom';
      flashMessage.classList.add('bg-white');
    } else if (type === 'success') {
      messageIcon.textContent = 'check_circle';
      messageIcon.classList.add('text-green-600');
      flashMessage.classList.add('bg-green-50', 'border-green-200');
    } else {
      messageIcon.textContent = 'error';
      messageIcon.classList.add('text-red-600');
      flashMessage.classList.add('bg-red-50', 'border-red-200');
    }
  }

  function hideMessage() {
    if (!flashMessage || !messageIcon) return;
    flashMessage.classList.add('hidden');
    flashMessage.classList.remove('show', 'bg-white', 'bg-green-50', 'bg-red-50', 'border-green-200', 'border-red-200');
    messageIcon.classList.remove('text-green-600', 'text-red-600');
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    const formData = new FormData(form);

    submitBtn.disabled = true;
    submitBtn.textContent = 'ENVIANDO...';
    showMessage('Por favor espera...', 'loading');

    try {
      const response = await fetch('https://formsubmit.co/ajax/nancyloschalets@gmail.com', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'Accept': 'application/json'
        },
        body: JSON.stringify(Object.fromEntries(formData))
      });

      if (response.ok) {
        showMessage('¡Gracias! Recibí tu solicitud y me pondré en contacto para coordinar la entrevista.', 'success');
        form.reset();
      } else {
        showMessage('Hubo un error al enviar el formulario. Por favor intentá de nuevo.', 'error');
      }
    } catch (error) {
      showMessage('Error de conexión. Verificá tu internet e intentá de nuevo.', 'error');
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = 'QUIERO MI ENTREVISTA';
      setTimeout(hideMessage, 6000);
    }
  });
</script>
