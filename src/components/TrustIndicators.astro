---
// Full-width credibility band, first thing under the hero.
const stats = [
  { number: '37', label: 'Países en operación' },
  { number: '7d', label: 'Comisiones semanales' },
  { number: '0', label: 'Stock e inventario' },
];
---

<div class="border-y border-primary-dark/15 bg-sage">
  <div class="grid grid-cols-3 divide-x divide-primary-dark/15">
    {stats.map((stat) => (
      <div class="px-6 md:px-12 py-6">
        <p class="font-fraunces font-semibold text-3xl md:text-5xl text-primary">{stat.number}</p>
        <p class="text-[10px] md:text-xs uppercase tracking-widest text-primary-dark/60 mt-1">
          {stat.label}
        </p>
      </div>
    ))}
  </div>
</div>
