---
export const prerender = true;

import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
import TrustIndicators from "../components/TrustIndicators.astro";
import AboutMe from "../components/AboutMe.astro";
import LifestyleGallery from "../components/LifestyleGallery.astro";
import VehiculoComercial from "../components/VehiculoComercial.astro";
import PersonalVideo from "../components/PersonalVideo.astro";
import Contact from "../components/Contact.astro";
import FAQ from "../components/FAQ.astro";
import Blog from "../components/Blog.astro";
import Footer from "../components/Footer.astro";
import WhatsAppButton from "../components/WhatsAppButton.astro";
import JoinTeamModal from "../components/JoinTeamModal.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../consts";

const siteUrl = 'https://nancysastre.com.ar';
const homeJsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'Nancy Sastre',
    url: siteUrl,
    inLanguage: 'es-AR',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Person',
    name: 'Nancy Sastre',
    url: siteUrl,
    image: `${siteUrl}/image/nancy-sastre-profile.png`,
    jobTitle: 'Mentora de negocios y empresaria independiente Fuxion',
    description: SITE_DESCRIPTION,
    sameAs: ['https://www.instagram.com/nancyemprendedora'],
  },
];
---

<BaseLayout title={SITE_TITLE} description={SITE_DESCRIPTION} jsonLd={homeJsonLd}>
    <Header />

    <!-- 1. Full-screen cinematic hero -->
    <Hero />

    <!-- 2. Credibility stats band, flush under the hero -->
    <TrustIndicators />

    <!-- 3. The commercial vehicle: product + corporate videos -->
    <VehiculoComercial />

    <!-- 4. Nancy's compact story: the success guarantee -->
    <AboutMe />

    <!-- 5. Lifestyle gallery: emotional peak before the application -->
    <LifestyleGallery />

    <!-- 6. Nancy's personal 1-min video: the invitation to apply -->
    <PersonalVideo />

    <!-- 7. Qualifying form (conversion) -->
    <Contact />

    <!-- 8. FAQ -->
    <FAQ />

    <!-- 9. Blog teaser -->
    <Blog />

    <Footer />
    <WhatsAppButton />
    <JoinTeamModal />
</BaseLayout>
