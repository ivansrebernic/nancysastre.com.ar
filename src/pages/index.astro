---
export const prerender = true;

import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
import TrustIndicators from "../components/TrustIndicators.astro";
import AboutMe from "../components/AboutMe.astro";
import LifestyleGallery from "../components/LifestyleGallery.astro";
import VehiculoComercial from "../components/VehiculoComercial.astro";
import About from "../components/About.astro";
import PersonalVideo from "../components/PersonalVideo.astro";
import BusinessPresentation from "../components/BusinessPresentation.astro";
import FunnelCTA from "../components/FunnelCTA.astro";
import Contact from "../components/Contact.astro";
import FAQ from "../components/FAQ.astro";
import Blog from "../components/Blog.astro";
import Footer from "../components/Footer.astro";
import WhatsAppButton from "../components/WhatsAppButton.astro";
import JoinTeamModal from "../components/JoinTeamModal.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../consts";
---

<BaseLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>
    <Header />

    <!-- 1. Business-focused hero -->
    <Hero />

    <!-- 2. Early credibility strip -->
    <section class="py-8">
        <div class="container-narrow">
            <TrustIndicators />
        </div>
    </section>

    <!-- 3. Nancy's story -->
    <AboutMe />

    <!-- 4. The commercial vehicle: product + corporate videos -->
    <VehiculoComercial />

    <!-- 5. Fuxion company context -->
    <div class="bg-gray-50/50">
        <About />
    </div>

    <!-- 6. Business presentation video + CTA -->
    <BusinessPresentation />

    <!-- 7. Scarcity CTA -->
    <FunnelCTA />

    <!-- 8. Lifestyle gallery: emotional peak before the application -->
    <LifestyleGallery />

    <!-- 9. Nancy's personal 1-min video: the invitation to apply -->
    <PersonalVideo />

    <!-- 10. Qualifying form (conversion) -->
    <Contact />

    <!-- 11. FAQ -->
    <FAQ />

    <!-- 12. Blog teaser -->
    <Blog />

    <Footer />
    <WhatsAppButton />
    <JoinTeamModal />
</BaseLayout>
